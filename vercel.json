{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/admin/*.ts": { "maxDuration": 300 },
    "api/team.ts": { "maxDuration": 300 }
  },
  "crons": [
    { "path": "/api/admin/analysis-worker", "schedule": "0 3 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; media-src 'self'; font-src 'self'; connect-src 'self' https://*.supabase.co https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; upgrade-insecure-requests" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/registro", "destination": "/index.html" },
    { "source": "/equipo", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/cambiar-contrasena", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/jurado", "destination": "/index.html" },
    { "source": "/mentor", "destination": "/index.html" }
  ]
}
