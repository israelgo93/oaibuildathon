# Navegador: se puede exponer. No coloques aqui una clave secreta.
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REEMPLAZAR

# Vercel Functions: variables exclusivas del servidor.
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SECRET_KEY=sb_secret_REEMPLAZAR
TEAM_SESSION_SECRET=genera_un_valor_aleatorio_de_al_menos_32_caracteres

# Opcional: proteccion anti-bots para el registro publico.
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Correo transaccional: solo servidor. Configura Production y Preview por separado.
RESEND_API_KEY=
RESEND_FROM=OpenAI Build Week Manta <noreply@datatensei.ai>
RESEND_REPLY_TO=
APP_BASE_URL=https://oaibuildathon.vercel.app

# Analisis IA de entregas: solo servidor. Configura Production y Preview por separado.
OPENAI_API_KEY=
# Opcional; si se omite, el servidor usa gpt-5.5, verificado con la clave local.
OPENAI_ANALYSIS_MODEL=gpt-5.5
# Opcional; token de GitHub de solo lectura para ampliar la cuota de repositorios publicos.
GITHUB_TOKEN=
# Secreto aleatorio de al menos 16 caracteres compartido con Vercel Cron.
CRON_SECRET=

# Solo para ejecutar npm run admin:bootstrap de forma local.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=
